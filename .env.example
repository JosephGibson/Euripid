# Euripid environment variables
#
# These are set automatically by scripts/run.ps1 and scripts/run.sh.
# You only need to set them manually when invoking k6 directly
# (see the "Direct k6 validation" section in docs/USAGE.md).
#
# Copy this file to .env for reference; do NOT commit a populated .env file.

# ---------------------------------------------------------------------------
# Core run parameters (required for direct k6 invocation)
# ---------------------------------------------------------------------------

# Key of the project directory under projects/
PROJECT=template-project

# Named environment variant from projects/<project>/project.config.json
ENVIRONMENT=self-test

# Path to the project config file (relative to repo root, from k6's CWD)
PROJECT_CONFIG_FILE=projects/template-project/project.config.json

# Path to the load profile JSON file
PROFILE_FILE=projects/template-project/profiles/smoke.json

# Directory where run artifacts are written (must exist before k6 starts)
RUN_OUTPUT_DIR=projects/template-project/results/direct-run

# ---------------------------------------------------------------------------
# Optional run parameters
# ---------------------------------------------------------------------------

# CSV dataset filename under projects/<project>/data/
# Falls back to project.config.json -> project.defaultDataFile when omitted
# DATA_FILE=users.csv

# ---------------------------------------------------------------------------
# Logging configuration
# ---------------------------------------------------------------------------

# Log verbosity: error | warn | info | debug  (default: error)
# EURIPID_LOG_LEVEL=error

# Emit structured EURIPID_ERROR JSON lines to k6 stderr: true | false  (default: true)
# EURIPID_LOG_SCENARIO_ERRORS=true

# Include username/role hints in structured error lines: true | false  (default: false)
# EURIPID_INCLUDE_USER_CONTEXT=false

# Include stack traces in structured error lines: true | false  (default: false)
# EURIPID_INCLUDE_STACK=false

# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------

# Write the full k6 summary payload instead of the slim subset: true | false  (default: false)
# EURIPID_WRITE_FULL_SUMMARY=false
